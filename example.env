# Django Core
SECRET_KEY=generate-a-new-random-key-here-for-security
DEBUG=False
ALLOWED_HOSTS=assets.miczon.com,localhost

# CSRF & CORS (Crucial for domain-to-domain communication)
CSRF_TRUSTED_ORIGINS=https://assets.miczon.com
CORS_ALLOWED_ORIGINS=https://assets.miczon.com

# Database (Keep these matching your docker-compose)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=inventory_db
DB_USER=inventory_user
DB_PASSWORD=inventory_pass
DB_HOST=db
DB_PORT=5432

# Google OAuth Credentials
GOOGLE_CLIENT_ID=301375751387-qujmvvouplhdekeg3p8cpjg2aabru0r5.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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

# Frontend & Login Redirects (The fix for your localhost issue)
FRONTEND_LOGIN_URL=https://assets.miczon.com/login
LOGIN_REDIRECT_URL=https://assets.miczon.com/

# Use this if you are using SSL behind Nginx
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
USE_X_FORWARDED_HOST=True